# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Turbopack / tooling caches (paths may appear under .next in dev)
.turbo/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local work library (seeded from works.starter.json on first run; do not commit your edits unless intentional)
/data/works.json

# Analysis flow output (generated locally; do not commit live file)
/data/lacuna-ai-flow.json
/data/lacuna-step1.json
# lacuna-ai-flow.starter.json is committed (bundled demo ghosts).
